# HI — Supabase Anbindung
# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# (Supabase Dashboard → Project Settings → API)
#
# Der "anon / public" Key ist für den Client gedacht und darf im Frontend liegen.
# Den "service_role" Key NIEMALS hier oder im Frontend verwenden.

VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key

# HI — KI-Coach (optional, standardmäßig aus)
# Auf "1" setzen, um den KI-Coach in den Übungsspielen einzublenden.
# Zusätzlich muss serverseitig ANTHROPIC_API_KEY in Vercel gesetzt sein,
# damit der Endpoint /api/feedback wirklich antwortet.
VITE_AI_COACH=0
# Nur serverseitig (Vercel → Settings → Environment Variables), NICHT ins Frontend:
# ANTHROPIC_API_KEY=sk-ant-...
