# HI — Supabase Anbindung
# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# (Supabase Dashboard → Project Settings → API)
#
# Der "anon / public" Key ist für den Client gedacht und darf im Frontend liegen.
# Den "service_role" Key NIEMALS hier oder im Frontend verwenden.

VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key
